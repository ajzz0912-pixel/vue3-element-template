{
  // 以项目 ESLint + .prettierrc 为准（通过 eslint-plugin-format）
  // 覆盖用户级 formatOnSave / Prettier 默认格式化器，避免冲突
  "editor.formatOnSave": false,
  "editor.defaultFormatter": null,
  "[javascript]": {
    "editor.defaultFormatter": null
  },
  "[typescript]": {
    "editor.defaultFormatter": null
  },
  "[vue]": {
    "editor.defaultFormatter": null
  },
  "[json]": {
    "editor.defaultFormatter": null
  },
  "[jsonc]": {
    "editor.defaultFormatter": null
  },
  "prettier.enable": false,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.fixAll.stylelint": "explicit",
    "source.organizeImports": "never"
  },
  "eslint.options": {
    "flags": []
  },
  // Silent the stylistic rules in you IDE, but still auto fix them
  "eslint.rules.customizations": [
    // { "rule": "@stylistic/*", "severity": "off" },
    // { "rule": "style*", "severity": "off" },
    // { "rule": "*-indent", "severity": "off" },
    // { "rule": "*-spacing", "severity": "off" },
    // { "rule": "*-spaces", "severity": "off" },
    // { "rule": "*-order", "severity": "off" },
    // { "rule": "*-dangle", "severity": "off" },
    // { "rule": "*-newline", "severity": "off" },
    // { "rule": "*quotes", "severity": "off" },
    // { "rule": "*semi", "severity": "off" }
  ],
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact",
    "vue",
    "html",
    "markdown",
    "json",
    "jsonc",
    "yaml",
    "toml",
    "xml",
    "svg",
    "gql",
    "graphql",
    "astro",
    "svelte",
    "css",
    "less",
    "scss",
    "pcss",
    "postcss"
  ],
  /**
   * 解决 unocss @apply 警告问题
   * @see https://github.com/tailwindlabs/tailwindcss/discussions/5258#discussioncomment-1979394
   */
  "scss.lint.unknownAtRules": "ignore",
  "stylelint.validate": ["css", "scss", "postcss", "less"],
  "svn.ignoreMissingSvnWarning": true
}
